        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="kafka_gen_msg" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.kafka.clients.producer.*
import java.util.Properties
import java.util.UUID
import java.util.concurrent.atomic.AtomicInteger




String threadName = Thread.currentThread().getName()
String producerKey = &quot;kafkaProducer_&quot; + threadName

def producer = props.get(producerKey)
if (producer == null) {
    Properties kafkaProps = new Properties()
    kafkaProps.put(&quot;bootstrap.servers&quot;, vars.get(&quot;bootstrap_servers&quot;))
    kafkaProps.put(&quot;key.serializer&quot;, &quot;org.apache.kafka.common.serialization.StringSerializer&quot;)
    kafkaProps.put(&quot;value.serializer&quot;, &quot;org.apache.kafka.common.serialization.StringSerializer&quot;)
    kafkaProps.put(&quot;acks&quot;, &quot;1&quot;)
    kafkaProps.put(&quot;linger.ms&quot;, &quot;0&quot;)
    kafkaProps.put(&quot;batch.size&quot;, &quot;16384&quot;)

    producer = new KafkaProducer&lt;String, String&gt;(kafkaProps)
    props.put(producerKey, producer)
    log.info(&quot;Created producer for &quot; + producerKey)
}

AtomicInteger globalCounter = props.get(&quot;globalCounter&quot;)
if (globalCounter == null){
    globalCounter = new AtomicInteger(0)
    props.put(&quot;globalCounter&quot;, globalCounter)
}

int msgNum = globalCounter.incrementAndGet()
String msgUuid = UUID.randomUUID().toString()
boolean head = (msgNum % 10 != 0)  

String json = &quot;&quot;&quot;{ &quot;msg_uuid\&quot;: \&quot;${msgUuid}\&quot;, \&quot;head\&quot;: \&quot;${head}\&quot;, \&quot;method\&quot;: \&quot;POST\&quot;, \&quot;uri\&quot;: \&quot;/post-message\&quot; }&quot;&quot;&quot;

producer.send(new ProducerRecord&lt;String, String&gt;(vars.get(&quot;topic&quot;), msgUuid, json))

return &quot;OK&quot;</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>

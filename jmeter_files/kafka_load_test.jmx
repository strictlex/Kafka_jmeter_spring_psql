        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="kafka_gen_msg">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.kafka.clients.producer.*
import java.util.Properties
import java.util.UUID

// --- Настройки Kafka ---
String bootstrapServers = &quot;localhost:9092&quot;   // замените на ваш адрес
String topic = &quot;message-topic&quot;                  // замените на ваш топик

// --- Создание или получение продюсера для этого потока ---
String threadName = Thread.currentThread().getName()
String producerKey = &quot;kafkaProducer_&quot; + threadName

def producer = props.get(producerKey)
if (producer == null) {
    Properties kafkaProps = new Properties()
    kafkaProps.put(&quot;bootstrap.servers&quot;, bootstrapServers)
    kafkaProps.put(&quot;key.serializer&quot;, &quot;org.apache.kafka.common.serialization.StringSerializer&quot;)
    kafkaProps.put(&quot;value.serializer&quot;, &quot;org.apache.kafka.common.serialization.StringSerializer&quot;)
    // Дополнительные настройки (опционально)
    kafkaProps.put(&quot;acks&quot;, &quot;1&quot;)
    kafkaProps.put(&quot;linger.ms&quot;, &quot;0&quot;)
    kafkaProps.put(&quot;batch.size&quot;, &quot;16384&quot;)

    producer = new KafkaProducer&lt;String, String&gt;(kafkaProps)
    props.put(producerKey, producer)
    log.info(&quot;Created producer for &quot; + producerKey)
}

// --- Генерация сообщения ---
// Счётчик сообщений для этого потока (хранится в props, ключ unique для потока)
String counterKey = &quot;counter_&quot; + threadName
int counter = props.get(counterKey) as Integer ?: 0
counter++
props.put(counterKey, counter)

// msg_uuid – случайный UUID
String msgUuid = UUID.randomUUID().toString()
// head: false каждое 10-е сообщение
boolean head = (counter % 10 != 0)   // true для 1..9, false для 10,20,...

// Формируем JSON
String json = String.format(
    &quot;{ \&quot;msg_uuid\&quot;: \&quot;%s\&quot;, \&quot;head\&quot;: %b, \&quot;method\&quot;: \&quot;POST\&quot;, \&quot;uri\&quot;: \&quot;/post-message\&quot; }&quot;,
    msgUuid, head
)

// --- Отправка ---
producer.send(new ProducerRecord&lt;String, String&gt;(topic, msgUuid, json))

// Возвращаем что-то, чтобы JMeter считал сэмплер успешным (можно просто вернуть &quot;OK&quot;)
return &quot;OK&quot;</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>

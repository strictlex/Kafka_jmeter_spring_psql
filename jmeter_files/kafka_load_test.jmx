      <JSR223Listener guiclass="TestBeanGUI" testclass="JSR223Listener" testname="JSR223 Listener" enabled="false">
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="script">import org.apache.kafka.clients.producer.KafkaProducer

props.keySet().each { key -&gt;
    if (key.toString().startsWith(&quot;kafkaProducer_&quot;)) {
        def producer = props.get(key)
        if (producer instanceof KafkaProducer) {
            producer.close()
            log.info(&quot;Closed producer for &quot; + key)
        }
    }
}</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
      </JSR223Listener>

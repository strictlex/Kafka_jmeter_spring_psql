        <JSR223Listener guiclass="TestBeanGUI" testclass="JSR223Listener" testname="Producer clouser" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.kafka.clients.producer.KafkaProducer

props.entrySet().each { entry -&gt;
    if (entry.key instanceof String &amp;&amp; entry.key.startsWith(&quot;kafkaProducer_&quot;)) {
        def producer = entry.value
        if (producer instanceof KafkaProducer) {
            producer.close()
            log.info(&quot;Closed producer for &quot; + entry.key)
            props.remove(entry.key)
        }
    }
}</stringProp>
        </JSR223Listener>
